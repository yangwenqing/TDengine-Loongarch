1 VERSIONINFO
 FILEVERSION ${BUILD_VER_NUMBER_COMMA}
 PRODUCTVERSION ${BUILD_VER_NUMBER_COMMA}
 FILEFLAGSMASK 0x17L
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x4L
 FILETYPE 0x0L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "FileDescription", "Python UDF Plugin for TDengine (Python ${Python3_VERSION})"
            VALUE "FileVersion", "${BUILD_VER_NUMBER}"
            VALUE "InternalName", "taospyudf.dll(${BUILD_VER_CPUTYPE})"
            VALUE "LegalCopyright", "Copyright (C) 2026 TAOS Data"
            VALUE "OriginalFilename", ""
            VALUE "ProductName", "taospyudf.dll(${BUILD_VER_CPUTYPE})"
            VALUE "ProductVersion", "${BUILD_VER_NUMBER}"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
